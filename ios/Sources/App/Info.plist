<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
  </array>
  <!-- Required for CLLocationManager.requestWhenInUseAuthorization. The
       pre-prime card (S00b LocationPermissionScreen) renders BEFORE this
       string surfaces, so the in-app voice owns the explanation. iOS shows
       this string in the native dialog the pre-prime CTA fires.

       Canonical source: ios/project.yml info.properties (XcodeGen merges
       this in on regenerate). Locked copy registered in
       design-system/surfaces/00b-location-permission.md "Copy register".
       Original TB-03 hand-edit superseded by bug-05 (ITMS-90683 fix). -->
  <key>NSLocationWhenInUseUsageDescription</key>
  <string>So we can line up restaurants close enough to walk to, instead of asking your neighborhood every time.</string>
</dict>
</plist>
