<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
  </array>
  <!-- TB-03 (v1.1) — required for CLLocationManager.requestWhenInUseAuthorization.
       The pre-prime card (S00b LocationPermissionScreen) renders BEFORE this
       string surfaces, so the in-app voice owns the explanation. iOS shows this
       string in the native dialog the pre-prime CTA fires. Plain-English single
       sentence, matches the pre-prime body register. -->
  <key>NSLocationWhenInUseUsageDescription</key>
  <string>GetToIt uses your location to line up restaurants close enough to walk to. Sharing is optional — you can type a place in instead.</string>
</dict>
</plist>
