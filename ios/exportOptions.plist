<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
GetToIt — Xcode export options for App Store / TestFlight uploads.

Consumed by `xcodebuild -exportArchive` in the `testflight` job in
`.github/workflows/ci.yml`. Pinned here (vs. flag-set on the command
line) so the export shape is reviewable in version control and
matches the App Store Connect record one-to-one.

Notes:
  * method=app-store is the broadly-compatible value across Xcode 14/15/16.
    Xcode 15.3+ also accepts `app-store-connect`; we stay with `app-store`
    for compat.
  * teamID is GetToIt's Apple Developer team (TB-00, paid account).
  * signingStyle=automatic + xcodebuild's `-allowProvisioningUpdates` flag
    means Xcode will auto-create the distribution cert and provisioning
    profile against the App Store Connect API key on first run.
  * uploadBitcode=false — Bitcode is deprecated (Xcode 14+).
  * uploadSymbols=true — ships dSYMs to ASC for symbolicated crash logs.
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store</string>
    <key>teamID</key>
    <string>WXTMNYM34A</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>uploadBitcode</key>
    <false/>
    <key>uploadSymbols</key>
    <true/>
    <key>destination</key>
    <string>export</string>
</dict>
</plist>
