# GetToIt — devcontainer environment template
#
# 1. Copy this file to `.env` in the repo root: `cp .env.example .env`
# 2. Fill in real values from the sources noted below.
# 3. `.env` is gitignored. Never commit real keys.
# 4. To load these into the container, either:
#    a) Source from your shell rc inside the container:
#         echo 'set -a && source /workspace/.env && set +a' >> ~/.zshrc
#    b) Reference them in `.devcontainer/devcontainer.json` via
#       `"runArgs": ["--env-file", "/workspace/.env"]` (rebuild required).
#
# See gti-vault/60_engineering/devcontainer-setup.md for full setup flow.
# These secrets are for LOCAL container use. CI secrets live in
# `gh secret set` and are listed in step 4 of the runbook.

# ──────────────────────────────────────────────────────────────────────
# GitHub
# ──────────────────────────────────────────────────────────────────────
# Fine-grained PAT. Create at: https://github.com/settings/personal-access-tokens
# Scope: this repo only. Permissions:
#   - Contents: read/write
#   - Pull requests: read/write
#   - Issues: read/write
#   - Workflows: read/write
#   - Actions: read/write
#   - Secrets: read/write   ← required for `gh secret set` from container
#
# Note: when GH_TOKEN is set in the environment, gh CLI uses it INSTEAD OF its
# stored OAuth login. If your PAT lacks "Secrets: read/write" you'll get
# `403 Resource not accessible by personal access token` on `gh secret set`.
# Workaround without bumping the PAT: run the command in a subshell with
# `unset GH_TOKEN GITHUB_TOKEN` so gh falls back to its OAuth auth.
GH_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Supabase — project credentials
# Source: supabase.com → your project → Settings → API
# ──────────────────────────────────────────────────────────────────────
# https://<project-ref>.supabase.co
SUPABASE_PROJECT_URL=

# Short identifier (the subdomain before .supabase.co)
SUPABASE_PROJECT_REF=

# Public anon key (safe-ish; client-side use)
SUPABASE_ANON_KEY=

# Service-role key (server/edge use only — full DB access, never ship to client)
SUPABASE_SERVICE_ROLE_KEY=

# DB password (set when project was created; needed for `supabase db push`)
SUPABASE_DB_PASSWORD=

# Personal access token for the `supabase` CLI
# Source: supabase.com → account → Access Tokens → Generate
SUPABASE_ACCESS_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Foursquare Places API
# Source: foursquare.com/developers → your app → API key
# ──────────────────────────────────────────────────────────────────────
FOURSQUARE_API_KEY=

# Vibe embeddings (server-only Edge Function runtime secrets)
# Source: voyageai.com -> API keys. Keep disabled until TB-09 enablement.
VOYAGE_API_KEY=
VIBE_EMBEDDINGS_ENABLED=false

# ──────────────────────────────────────────────────────────────────────
# Vercel (web fallback deploys — optional in container; CI handles prod)
# Source: vercel.com → account → Settings → Tokens
# ──────────────────────────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ──────────────────────────────────────────────────────────────────────
# Apple Developer / EAS release (NOT used inside container). The active
# React Native app lives in `mobile/`; EAS handles iOS signing and
# TestFlight submission for that app. Keep local paths private.
# ──────────────────────────────────────────────────────────────────────
# APPLE_TEAM_ID=
# APPLE_BUNDLE_ID=app.gettoit.GetToIt
# APPLE_API_KEY_ID=
# APPLE_API_ISSUER_ID=
# APPLE_API_PRIVATE_KEY_PATH=  # path to AuthKey_XXXX.p8 on your local machine
# APNS_AUTH_KEY_ID=  # 10-char APNs key ID (live copy in Supabase Edge Function secrets)
# APNS_AUTH_KEY_PATH=  # path to APNs AuthKey_XXXX.p8 on your local machine

# ──────────────────────────────────────────────────────────────────────
# Optional / future
# ──────────────────────────────────────────────────────────────────────
# Sentry, PostHog, OpenAI, etc. — add as features land.
