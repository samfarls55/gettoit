{
  "name": "gettoit-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "GetToIt monorepo root. Houses mobile/, web/, supabase/, docs/, gti-vault/ as siblings per ADR 0004.",
  "scripts": {
    "verify:web": "npm run web:typecheck && npm run web:test && npm run web:build",
    "verify:edge": "node scripts/run-edge-tests.mjs",
    "verify:local": "npm run verify:web && npm run verify:edge",
    "web:typecheck": "npm run typecheck --prefix web",
    "web:test": "npm test --prefix web",
    "web:build": "npm run build --prefix web",
    "web:dev": "npm run dev --prefix web",
    "mobile:typecheck": "npm run typecheck --prefix mobile",
    "mobile:test": "npm test --prefix mobile",
    "mobile:web": "npm run web --prefix mobile",
    "mobile:verify": "npm run verify --prefix mobile",
    "typecheck": "npm run mobile:typecheck",
    "test": "npm run mobile:test",
    "sandcastle": "npx tsx .sandcastle/main.mts",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.7.0",
    "zod": "^4.4.3"
  }
}
