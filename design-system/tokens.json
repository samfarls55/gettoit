{
  "$schema": "./scripts/tokens.schema.json",
  "_note": "Canonical source of truth for Sunset Pop tokens. Edit here, regenerate code/tokens.css via scripts/gen-css.mjs. Future scripts/gen-swift.mjs emits GTITokens.swift from the same source.",
  "color": {
    "ink": "#0E1011",
    "ink-2": "#1A1C1F",
    "ink-3": "#0A0A0F",
    "_ink-3-note": "Hard-close shutter fill (S06). Deeper than ink/ink-2 to read as a surface seal. ink-2 is reroll sheet, ink-3 is shutter — different surface depths.",
    "paper": "#FFFFFF",
    "sun": "#FFD23F",
    "sun-deep": "#F5B800",
    "member-identity": ["#7DDFB5", "#FF8DA1", "#9BC0FF"],
    "_member-identity-note": "Per-member dot color on waiting surface (S08). Tension with §1 'Sun is THE accent — don't dilute' rule: justified because identity != state signal, but flag for design review if palette expands beyond 3 members.",
    "chrome": {
      "imessage": ["#1C1C1E", "#26262A", "#3A3A3C"],
      "_imessage-note": "External iOS Messages dark-theme chrome mocked in ScreenInviteUnfurl. Registered so the orphan-hex sweep stays green; NOT GetToIt brand colors."
    },
    "glass": {
      "fill": "rgba(255,255,255,0.18)",
      "fill-strong": "rgba(255,255,255,0.28)",
      "fill-soft": "rgba(255,255,255,0.10)",
      "fill-soft-press": "rgba(255,255,255,0.16)",
      "_fill-soft-press-note": "Pressed state for soft-glass rows (C-23 LocationPicker suggestion row). Sits between fill-soft (0.10, default) and fill (0.18, hover/selected). Press feedback only — not a selected state; selected uses sun like every other state in the system.",
      "stroke": "rgba(255,255,255,0.42)"
    },
    "text": {
      "on-gradient": {
        "primary": "#FFFFFF",
        "secondary": "rgba(255,255,255,0.78)",
        "tertiary": "rgba(255,255,255,0.6)"
      },
      "on-surface": {
        "primary": "#0E1011",
        "secondary": "rgba(14,16,17,0.7)",
        "tertiary": "rgba(14,16,17,0.5)"
      }
    }
  },
  "gradient": {
    "stop-positions": [0, 0.32, 0.66, 1.0],
    "tween-from": "initiator",
    "surfaces": {
      "initiator": ["#FF8868", "#FF9F6B", "#FFB855", "#FFD23F"],
      "q1":        ["#FF6B5E", "#FF8A5F", "#FFB256", "#FFD23F"],
      "q2":        ["#FF5878", "#FF7A66", "#FFA15A", "#FFC75A"],
      "q3":        ["#E04F8B", "#B855B0", "#8A5BD0", "#6E63E0"],
      "q4":        ["#2F3380", "#3F47A6", "#5E59C9", "#7C68E4"],
      "q5":        ["#0E1450", "#181B5E", "#252A6E", "#363B82"],
      "waiting":   ["#1B1F66", "#2A2A7C", "#4A3F9F", "#7256C4"],
      "verdict":   ["#FFC548", "#FF8A5A", "#C24F7E", "#2A2068"],
      "checkin":   ["#FFDB6B", "#FFA86D", "#FF7F88", "#9F4C9F"],
      "midnight":  ["#0A0B1A", "#10112A", "#161836", "#1F2244"]
    }
  },
  "vibe-labels": ["HUSHED", "MELLOW", "BUZZY", "LOUD", "ROWDY"],
  "typography": {
    "families": {
      "display": "'Inter', system-ui, -apple-system, sans-serif",
      "body":    "'Inter', system-ui, -apple-system, sans-serif",
      "mono":    "'IBM Plex Mono', ui-monospace, Menlo, monospace"
    },
    "display-weight": 900,
    "scale": {
      "display-xl": { "size": 88, "weight": 900, "tracking": "-0.025em", "line-height": 0.9,  "family": "display" },
      "display-l":  { "size": 64, "weight": 900, "tracking": "-0.025em", "line-height": 0.9,  "family": "display" },
      "display-m":  { "size": 44, "weight": 900, "tracking": "-0.025em", "line-height": 0.92, "family": "display" },
      "display-s":  { "size": 32, "weight": 900, "tracking": "-0.02em",  "line-height": 0.95, "family": "display" },
      "heading":    { "size": 28, "weight": 800, "tracking": "-0.015em", "line-height": 1.05, "family": "display" },
      "title":      { "size": 22, "weight": 700, "tracking": "-0.01em",  "line-height": 1.2,  "family": "body" },
      "body":       { "size": 16, "weight": 600, "tracking": "0",        "line-height": 1.4,  "family": "body" },
      "sm":         { "size": 14, "weight": 600, "tracking": "0",        "line-height": 1.4,  "family": "body" },
      "eyebrow":    { "size": 11, "weight": 700, "tracking": "0.18em",   "line-height": 1,    "family": "body",  "case": "upper" },
      "cta":        { "size": 14, "weight": 800, "tracking": "0.14em",   "line-height": 1,    "family": "body",  "case": "upper" },
      "mono-tag":   { "size": 11, "weight": 500, "tracking": "0.18em",   "line-height": 1,    "family": "mono",  "case": "upper" }
    },
    "tracking": {
      "eyebrow": "0.18em",
      "cta":     "0.14em",
      "display": "-0.025em"
    }
  },
  "spacing": {
    "1":  4,
    "2":  8,
    "3":  12,
    "4":  16,
    "5":  20,
    "6":  24,
    "8":  32,
    "10": 40,
    "12": 48,
    "16": 64
  },
  "radii": {
    "chip":    999,
    "tag":     8,
    "row":     12,
    "card":    18,
    "card-lg": 22,
    "hero":    28,
    "pill":    999,
    "sheet":   26
  },
  "shadow": {
    "cta-white":       "0 12px 32px rgba(0,0,0,0.18)",
    "cta-sun":         "0 12px 32px rgba(255,210,63,0.4), inset 0 1px 0 rgba(255,255,255,0.45)",
    "time-badge":      "0 18px 38px rgba(255,210,63,0.36), inset 0 1px 0 rgba(255,255,255,0.5)",
    "chip-selected":   "0 8px 22px rgba(255,210,63,0.35), 0 0 0 4px rgba(255,210,63,0.18), inset 0 1px 0 rgba(255,255,255,0.5)",
    "receipt-glass":   "inset 0 1px 0 rgba(255,255,255,0.25), 0 4px 10px rgba(0,0,0,0.08)",
    "sheet":           "0 -20px 60px rgba(0,0,0,0.5)"
  },
  "motion": {
    "easing": {
      "out":      "cubic-bezier(.22,.61,.36,1)",
      "out-soft": "cubic-bezier(.16,1,.3,1)",
      "in-out":   "cubic-bezier(.65,0,.35,1)"
    },
    "duration-ms": {
      "grad-tween": 1100,
      "chip":       180,
      "rise":       700,
      "pop":        520,
      "shutter":    700
    },
    "choreo-delay-ms": {
      "stagger-receipt": 80,
      "eyebrow":         80,
      "name":            280,
      "meta":            700,
      "time":            820,
      "rule":            1020,
      "receipts":        1140,
      "cta":             1380
    }
  },
  "texture": {
    "grain-opacity": 0.35,
    "grain-blend":   "overlay",
    "grain-tile-px": 280
  }
}
