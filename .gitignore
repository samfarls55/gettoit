# Local legacy Claude Code config (agent definitions, skills, local settings)
.claude/

# Obsidian local workspace state (per-machine window layout, recents)
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json
**/.obsidian/graph.json

# OS / editor cruft
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p8
secrets/

# Supabase CLI local state (pooler URL contains DB password in plaintext)
supabase/.temp/
supabase/.branches/

# Sandcastle local state (secrets, sandbox worktrees, logs, sandbox-local auth)
.sandcastle/.env
.sandcastle/codex-home/
.sandcastle/gitconfig
.sandcastle/logs/
.sandcastle/worktrees/

# Deno-generated lockfile (deno 2.x writes one at the repo root when
# tests run from a subdir without an explicit deno.json). CI generates
# its own; we don't pin transitive versions here.
deno.lock

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependencies (pre-emptive — no code yet)
node_modules/
.pnpm-store/
__pycache__/
*.pyc
.venv/
venv/
target/
vendor/

# Build output (pre-emptive)
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.turbo/
coverage/

# Expo local state
.expo/

# TypeScript incremental build cache
*.tsbuildinfo

